{
    "schemaVersion": 1,
    "id": "prosperity",
    "version": "${version}",
    "name": "Prosperity",
    "description": "A loot overhaul for Minecraft. Per-player instanced container loot plus distance-based loot scaling, so every chest is yours to discover and exploration always pays off.",
    "authors": ["rfizzle"],
    "contact": {
        "homepage": "https://prosperity.rfizzle.com",
        "sources": "https://github.com/rfizzle/prosperity",
        "issues": "https://github.com/rfizzle/prosperity/issues"
    },
    "license": "MIT",
    "icon": "assets/prosperity/icon.png",
    "environment": "*",
    "entrypoints": {
        "main": ["com.rfizzle.prosperity.Prosperity"],
        "client": ["com.rfizzle.prosperity.client.ProsperityClient"],
        "modmenu": ["com.rfizzle.prosperity.compat.modmenu.ModMenuIntegration"],
        "jade": ["com.rfizzle.prosperity.compat.jade.ProsperityJadePlugin"],
        "emi": ["com.rfizzle.prosperity.compat.emi.ProsperityEmiPlugin"],
        "rei_client": ["com.rfizzle.prosperity.compat.rei.ProsperityReiClientPlugin"],
        "jei_mod_plugin": ["com.rfizzle.prosperity.compat.jei.ProsperityJeiPlugin"],
        "fabric-datagen": ["com.rfizzle.prosperity.data.ProsperityDataGenerator"],
        "fabric-gametest": [
            "com.rfizzle.prosperity.gametest.AbsentPlayerEvictionGameTest",
            "com.rfizzle.prosperity.gametest.BlacklistGameTest",
            "com.rfizzle.prosperity.gametest.BlockHopperInstancingGameTest",
            "com.rfizzle.prosperity.gametest.ContainerProtectionGameTest",
            "com.rfizzle.prosperity.gametest.ContainerTooltipGameTest",
            "com.rfizzle.prosperity.gametest.ContainerRemovalGameTest",
            "com.rfizzle.prosperity.gametest.DistanceTierApiGameTest",
            "com.rfizzle.prosperity.gametest.DoubleChestGameTest",
            "com.rfizzle.prosperity.gametest.FakePlayerGuardGameTest",
            "com.rfizzle.prosperity.gametest.FishingLootScalingGameTest",
            "com.rfizzle.prosperity.gametest.InstancedLootDataGameTest",
            "com.rfizzle.prosperity.gametest.InstancedLootGameTest",
            "com.rfizzle.prosperity.gametest.LootInjectionGameTest",
            "com.rfizzle.prosperity.gametest.LootModifierGameTest",
            "com.rfizzle.prosperity.gametest.LootNotificationGameTest",
            "com.rfizzle.prosperity.gametest.LootNullificationGameTest",
            "com.rfizzle.prosperity.gametest.LootRefreshGameTest",
            "com.rfizzle.prosperity.gametest.LootScalingGameTest",
            "com.rfizzle.prosperity.gametest.LootStatsGameTest",
            "com.rfizzle.prosperity.gametest.LootIndexSyncGameTest",
            "com.rfizzle.prosperity.gametest.LootTableInspectorGameTest",
            "com.rfizzle.prosperity.gametest.MinecartIndicatorGameTest",
            "com.rfizzle.prosperity.gametest.MinecartInstancingGameTest",
            "com.rfizzle.prosperity.gametest.MobLootScalingGameTest",
            "com.rfizzle.prosperity.gametest.ProsperityCommandGameTest",
            "com.rfizzle.prosperity.gametest.StructureCompletionGameTest",
            "com.rfizzle.prosperity.gametest.StructureScalingGameTest",
            "com.rfizzle.prosperity.gametest.TrialChamberScalingGameTest",
            "com.rfizzle.prosperity.gametest.UnlootedSyncGameTest"
        ]
    },
    "suggests": {
        "modmenu": "*",
        "jade": "*",
        "wthit": "*",
        "emi": "*",
        "roughlyenoughitems": "*",
        "jei": "*",
        "tribulation": "*"
    },
    "mixins": [
        "prosperity.mixins.json"
    ],
    "depends": {
        "fabricloader": ">=0.16.10",
        "minecraft": "~1.21.1",
        "java": ">=21",
        "fabric-api": "*"
    }
}
