# gradle
.gradle/
build/
out/
classes/

# loom dev runtime
run/
mods/
logs/
# Root-anchored: the dev-runtime config dir only. A bare `config/` would also
# match the `…/prosperity/config/` Java source package and silently drop it.
/config/

# IDE
.idea/
*.iml
*.ipr
*.iws
.settings/
.vscode/
.classpath
.project
*.launch

# local AI / planning state
.claude/settings.local.json
.claude/projects/
.claude/scheduled_tasks.lock
.plan/

# Fabric datagen hash cache — timestamps inside these files change every run,
# so committing them would make `./gradlew runDatagen` non-idempotent against
# git. The actual generated assets/data under src/main/generated are committed.
src/main/generated/.cache/

# generated website
_site/

# OS junk
.DS_Store
Thumbs.db
*:Zone.Identifier

# stray runtime artifacts
replay_pid*.log
hs_err_pid*.log
